      "-S",
      "$ZED_WORKTREE_ROOT",
      "-B",
      "$ZED_WORKTREE_ROOT/build",
      "-DCMAKE_BUILD_TYPE=Release"
    ],
    "env": {}
  },
  {
    "label": "CMake: Build (Release)",
    "command": "cmake",
    "args": [
      "--build",
      "$ZED_WORKTREE_ROOT/build",
      "--config",
      "Release"
    ],
    "env": {}
  }
