[
  {
    "label": "CMake: Configure (Debug)",
    "command": "cmake",
    "args": [
      "-S",
      "$ZED_WORKTREE_ROOT",
      "-B",
      "$ZED_WORKTREE_ROOT/build",
      "-DCMAKE_BUILD_TYPE=Debug"
    ],
    "env": {}
  },
  {
    "label": "CMake: Build (Debug)",
    "command": "cmake",
    "args": [
      "--build",
      "$ZED_WORKTREE_ROOT/build",
      "--config",
      "Debug"
    ],
    "env": {}
  },
  {
    "label": "CMake: Configure (Release)",
